# MongoDB connection string
# Option 1: Local MongoDB (default - requires MongoDB installed locally)
MONGO_URI=mongodb://127.0.0.1:27017/planetplayground

# Option 2: MongoDB Atlas (cloud, free — replace with your own URI)
# MONGO_URI=mongodb+srv://youruser:yourpassword@cluster0.xxxxx.mongodb.net/planetplayground

# JWT secret key (change this to any long random string in production)
JWT_SECRET=planet_playground_super_secret_2025

# Server port
PORT=3000
